<mvc:View
    controllerName="priceamendmentautomation.controller.PriceAutomation"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    displayBlock="true"
>
    <Page
        title="Raw Material Price Revision"
        showNavButton="false"
        backgroundDesign="Transparent"
        showHeader="false"
    >
        <customHeader>
            <Bar design="Header">
                <contentLeft>
                    <Title
                        text="Raw Material Price Revision"
                        level="H4"
                    />
                </contentLeft>
                <contentRight>
                    <Button
                        text="Reset"
                        type="Transparent"
                        press=".onReset"
                    />
                    <Button
                        text="Save"
                        type="Emphasized"
                        icon="sap-icon://save"
                        press=".onSave"
                    />
                </contentRight>
            </Bar>
        </customHeader>

        <content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                <Panel
                    expandable="false"
                    class="sapUiNoContentPadding"
                >
                    <headerToolbar>
                        <OverflowToolbar
                            style="Clear"
                            height="2.5rem"
                        >
                            <ToolbarSeparator />
                            <Label
                                text="V Code"
                                design="Bold"
                                class="sapUiTinyMarginEnd"
                            />
                            <Select
                                id="selVendorCode"
                                selectedKey="{view>/selectedVendorCode}"
                                change=".onVendorChange"
                                width="130px"
                            >
                                <items>
                                    <core:Item
                                        key=""
                                        text="-- Select --"
                                    />
                                </items>
                            </Select>
                            <ToolbarSeparator />
                            <Label
                                text="Commodity"
                                design="Bold"
                                class="sapUiTinyMarginEnd"
                            />
                            <Select
                                id="selCommodity"
                                selectedKey="{view>/selectedCommodity}"
                                change=".onCommodityChange"
                                width="150px"
                            >
                                <items>
                                    <core:Item
                                        key=""
                                        text="-- Select --"
                                    />
                                </items>
                            </Select>
                            <ToolbarSeparator />
                            <Label
                                text="Effective Date:"
                                design="Bold"
                                class="sapUiTinyMarginEnd"
                            />
                            <DatePicker
                                id="dpEffectiveDate"
                                value="{view>/vendorData/effectiveDate}"
                                valueFormat="yyyy-MM-dd"
                                displayFormat="dd/MM/yyyy"
                                width="120px"
                                class="rmpEditableInput"
                            />
                            <ToolbarSeparator />
                            <Label
                                text="Currency:"
                                design="Bold"
                                class="sapUiTinyMarginEnd"
                            />
                            <Text text="{view>/vendorData/currency_code}" />
                            <ToolbarSeparator />
                            <Label
                                text="Current Rate:"
                                design="Bold"
                                class="sapUiTinyMarginEnd"
                            />
                            <ObjectNumber
                                number="{path: 'view>/currency/currentRate', formatter: '.formatter.formatDecimal'}"
                                state="None"
                                class="sapUiTinyMarginEnd"
                            />
                            <Label
                                text="New Rate:"
                                design="Bold"
                                class="sapUiTinyMarginEnd"
                            />
                            <Input
                                id="inputNewCurrRate"
                                value="{view>/currency/newRate}"
                                type="Number"
                                valueLiveUpdate="true"
                                liveChange=".onCurrencyChange"
                                width="80px"
                                class="rmpEditableInput"
                            />
                            <Label
                                text="Content:"
                                design="Bold"
                                class="sapUiTinyMarginEnd"
                            />
                            <ObjectNumber
                                number="{path: 'view>/currency/deltaRate', formatter: '.formatter.formatDecimal'}"
                                state="{path: 'view>/currency/deltaRate', formatter: '.formatter.formatDeltaState'}"
                            />
                            <ToolbarSpacer />
                        </OverflowToolbar>
                    </headerToolbar>

                    <t:Table
                        id="rmTable"
                        rows="{view>/rmPrices}"
                        selectionMode="None"
                        alternateRowColors="true"
                        columnHeaderHeight="32"
                        visibleRowCount="5"
                        showNoData="false"
                    >
                        <t:extension>
                            <OverflowToolbar
                                style="Clear"
                                height="2rem"
                            >
                                <Title
                                    text="Raw Material Rates"
                                    level="H6"
                                />
                                <ToolbarSpacer />
                                <Button
                                    text="Reset"
                                    type="Transparent"
                                    press=".onReset"
                                />
                                <Button
                                    text="Save"
                                    type="Emphasized"
                                    icon="sap-icon://save"
                                    press=".onSave"
                                />
                            </OverflowToolbar>
                        </t:extension>

                        <t:columns>
                            <t:Column>
                                <Label text="RM Code" />
                                <t:template>
                                    <Text
                                        text="{view>rmCode}"
                                        wrapping="false"
                                    />
                                </t:template>
                            </t:Column>

                            <t:Column width="130px">
                                <Label text="RM" />
                                <t:template>
                                    <Text
                                        text="{view>rmName}"
                                        wrapping="false"
                                    />
                                </t:template>
                            </t:Column>

                            <t:Column
                                width="120px"
                                hAlign="End"
                            >
                                <Label text="Current RM Rate" />
                                <t:template>
                                    <ObjectNumber
                                        number="{path: 'view>currentRmRate', formatter: '.formatter.formatDecimal'}"
                                        state="None"
                                    />
                                </t:template>
                            </t:Column>

                            <t:Column
                                width="120px"
                                hAlign="End"
                            >
                                <Label text="New RM Rate" />
                                <t:template>
                                    <Input
                                        value="{view>newRmRate}"
                                        type="Number"
                                        valueLiveUpdate="true"
                                        liveChange=".onRmRateChange"
                                        class="rmpEditableInput"
                                        width="60px"
                                    />
                                </t:template>
                            </t:Column>

                            <t:Column
                                width="110px"
                                hAlign="End"
                            >
                                <Label text="Content" />
                                <t:template>
                                    <ObjectNumber
                                        number="{path: 'view>deltaContentRate', formatter: '.formatter.formatDecimal'}"
                                        state="Error"
                                    />
                                </t:template>
                            </t:Column>

                            <t:Column
                                width="130px"
                                hAlign="End"
                            >
                                <Label text="Current Scrap Rate" />
                                <t:template>
                                    <ObjectNumber
                                        number="{path: 'view>currentScrapRate', formatter: '.formatter.formatDecimal'}"
                                        state="None"
                                    />
                                </t:template>
                            </t:Column>

                            <t:Column
                                width="120px"
                                hAlign="End"
                            >
                                <Label text="New Scrap Rate" />
                                <t:template>
                                    <Input
                                        value="{view>newScrapRate}"
                                        type="Number"
                                        valueLiveUpdate="true"
                                        liveChange=".onScrapRateChange"
                                        class="rmpEditableInput"
                                        width="60px"
                                    />
                                </t:template>
                            </t:Column>

                            <t:Column
                                width="120px"
                                hAlign="End"
                            >
                                <Label text="Scrap" />
                                <t:template>
                                    <ObjectNumber
                                        number="{path: 'view>deltaScrapRate', formatter: '.formatter.formatDecimal'}"
                                        state="Error"
                                    />
                                </t:template>
                            </t:Column>

                            <t:Column
                                width="150px"
                                hAlign="End"
                            >
                                <Label text="Overall RM Impact" />
                                <t:template>
                                    <ObjectNumber
                                        number="{path: 'view>overallRmImpact', formatter: '.formatter.formatDecimal'}"
                                        state="{path: 'view>overallRmImpact', formatter: '.formatter.formatDeltaState'}"
                                        emphasized="true"
                                    />
                                </t:template>
                            </t:Column>
                        </t:columns>
                    </t:Table>

                    <OverflowToolbar
                        style="Clear"
                        height="2rem"
                        class="sapUiTinyMarginTop"
                    >
                        <Title
                            text="Charges &amp; Overheads"
                            level="H6"
                        />
                    </OverflowToolbar>

                    <Table
                        items="{view>/charges}"
                        showSeparators="Inner"
                        backgroundDesign="Transparent"
                        fixedLayout="false"
                        class="sapUiSizeCompact"
                    >
                        <columns>
                            <Column width="120px">
                                <Label text="Charge" />
                            </Column>
                            <Column
                                width="80px"
                                hAlign="End"
                            >
                                <Label text="Rate" />
                            </Column>
                            <Column width="100px">
                                <Label text="Apply" />
                            </Column>
                            <Column>
                                <Label text="Note" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{view>name}" />
                                    <ObjectNumber
                                        number="{path: 'view>rate', formatter: '.formatter.formatRate'}"
                                        unit="%"
                                    />
                                    <Select
                                        selectedKey="{view>apply}"
                                        class="rmpEditableSelect"
                                        width="90px"
                                    >
                                        <core:Item
                                            key="Yes"
                                            text="Yes"
                                        />
                                        <core:Item
                                            key="No"
                                            text="No"
                                        />
                                    </Select>
                                    <Text text="Default No" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>
            </VBox>
        </content>
    </Page>
</mvc:View>
